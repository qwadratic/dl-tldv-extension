{
  "name": "dl-tldv-extension",
  "version": "1.0.0",
  "description": "Browser extension to download tldv.io meeting recordings as MP4",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "package": "cd dist && zip -r dl-tldv-chrome.zip . -x '*.map' && cp dl-tldv-chrome.zip dl-tldv-firefox.zip",
    "release": "npm version patch && git push --follow-tags"
  },
  "keywords": ["tldv", "browser-extension", "video-download", "ffmpeg-wasm"],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
